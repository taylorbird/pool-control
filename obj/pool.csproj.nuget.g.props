<?xml version="1.0" encoding="utf-8" standalone="no"?>
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <RestoreSuccess Condition=" '$(RestoreSuccess)' == '' ">True</RestoreSuccess>
    <RestoreTool Condition=" '$(RestoreTool)' == '' ">NuGet</RestoreTool>
    <ProjectAssetsFile Condition=" '$(ProjectAssetsFile)' == '' ">$(MSBuildThisFileDirectory)project.assets.json</ProjectAssetsFile>
    <NuGetPackageRoot Condition=" '$(NuGetPackageRoot)' == '' ">/Users/tbird/.nuget/packages/</NuGetPackageRoot>
    <NuGetPackageFolders Condition=" '$(NuGetPackageFolders)' == '' ">/Users/tbird/.nuget/packages/</NuGetPackageFolders>
    <NuGetProjectStyle Condition=" '$(NuGetProjectStyle)' == '' ">PackageReference</NuGetProjectStyle>
    <NuGetToolVersion Condition=" '$(NuGetToolVersion)' == '' ">6.1.0</NuGetToolVersion>
  </PropertyGroup>
  <ItemGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <SourceRoot Include="/Users/tbird/.nuget/packages/" />
  </ItemGroup>
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <PkgAWSSDK_Core Condition=" '$(PkgAWSSDK_Core)' == '' ">/Users/tbird/.nuget/packages/awssdk.core/3.7.9</PkgAWSSDK_Core>
    <PkgAWSSDK_TimestreamWrite Condition=" '$(PkgAWSSDK_TimestreamWrite)' == '' ">/Users/tbird/.nuget/packages/awssdk.timestreamwrite/3.7.1.35</PkgAWSSDK_TimestreamWrite>
    <PkgAWSSDK_TimestreamQuery Condition=" '$(PkgAWSSDK_TimestreamQuery)' == '' ">/Users/tbird/.nuget/packages/awssdk.timestreamquery/3.7.2.2</PkgAWSSDK_TimestreamQuery>
  </PropertyGroup>
</Project>